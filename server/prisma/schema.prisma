generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum OrderStatus {
  NEW
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

// ============================================
// MODELS
// ============================================

/// Global Settings for the single cafe
model Settings {
  id           String   @id @default("default")
  name         String   @default("My Cafe")
  description  String?
  email        String?
  phone        String?
  currency     String   @default("INR")
  taxRate      Float    @default(5.0)
  taxInclusive Boolean  @default(false)
  primaryColor String   @default("#8B6F47")
  acceptOrders Boolean  @default(true)
  logoUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// Admin/staff user with RBAC
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(STAFF)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// JWT refresh tokens — stored server-side for rotation & revocation
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  userAgent String?
  ipAddress String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

/// Menu category (Coffee, Tea, Desserts, etc.)
model Category {
  id        String @id @default(uuid())
  name      String
  slug      String @unique
  emoji     String @default("🍽️")
  color     String @default("#8B6F47")
  sortOrder Int    @default(0)

  items MenuItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

/// Menu item
model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int
  image       String?
  isPopular   Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  isAvailable Boolean  @default(true)
  tags        String[] @default([])
  sortOrder   Int      @default(0)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_items")
}

/// Physical table in the cafe
model CafeTable {
  id       String  @id @default(uuid())
  number   Int     @unique
  label    String
  isActive Boolean @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tables")
}

/// Customer order
model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  status              OrderStatus @default(NEW)
  subtotal            Int
  tax                 Int
  total               Int
  specialInstructions String?

  tableId String
  table   CafeTable @relation(fields: [tableId], references: [id], onDelete: Restrict)

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

/// Line item within an order (snapshot of menu item at time of order)
model OrderItem {
  id        String @id @default(uuid())
  quantity  Int
  unitPrice Int
  name      String

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  menuItemId String?
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@map("order_items")
}
